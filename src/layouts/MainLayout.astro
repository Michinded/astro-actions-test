---
interface Props {
  title: string;
}

const { title } = Astro.props;
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <style>
      * { box-sizing: border-box; }
      body {
        font-family: system-ui, sans-serif;
        margin: 0;
        padding: 0;
      }
      header {
        background: #1a1a2e;
        padding: 16px;
      }
      nav {
        max-width: 720px;
        margin: 0 auto;
        display: flex;
        gap: 16px;
        flex-wrap: wrap;
      }
      nav a {
        color: #fff;
        text-decoration: none;
        padding: 8px 16px;
        border-radius: 8px;
        background: rgba(255,255,255,0.1);
        transition: background 0.2s;
      }
      nav a:hover {
        background: rgba(255,255,255,0.2);
      }
      nav a.active {
        background: #6366f1;
      }
      main {
        max-width: 720px;
        margin: 40px auto;
        padding: 0 16px;
      }
      form {
        display: grid;
        gap: 12px;
        border: 1px solid #ddd;
        padding: 16px;
        border-radius: 12px;
      }
      input, textarea, button {
        font: inherit;
        padding: 10px;
      }
      textarea { min-height: 120px; }
      .ok {
        padding: 12px;
        border-radius: 10px;
        background: #eefbf0;
        border: 1px solid #bde5c4;
        margin-bottom: 16px;
      }
      .err {
        padding: 12px;
        border-radius: 10px;
        background: #fff0f0;
        border: 1px solid #f0b6b6;
        margin-bottom: 16px;
      }
      code { background: #f6f6f6; padding: 2px 6px; border-radius: 6px; }
      .badge {
        display: inline-block;
        font-size: 12px;
        padding: 4px 8px;
        border-radius: 4px;
        background: #e0e7ff;
        color: #3730a3;
        margin-left: 8px;
      }
    </style>
  </head>

  <body>
    <header>
      <nav>
        <a href="/" class:list={{ active: currentPath === '/' }}>
          Form POST
        </a>
        <a href="/con-redirect" class:list={{ active: currentPath === '/con-redirect' }}>
          Con Redirect
        </a>
        <a href="/con-js" class:list={{ active: currentPath === '/con-js' }}>
          Con JavaScript
        </a>
      </nav>
    </header>

    <main>
      <slot />
    </main>
  </body>
</html>
