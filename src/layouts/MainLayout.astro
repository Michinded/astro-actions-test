---
import { actions } from 'astro:actions';
import type { User } from '../lib/auth';

interface Props {
  title: string;
  user?: User | null;
}

const { title, user = null } = Astro.props;
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <style>
      * { box-sizing: border-box; }
      body {
        font-family: system-ui, sans-serif;
        margin: 0;
        padding: 0;
      }
      header {
        background: #1a1a2e;
        padding: 16px;
      }
      .header-content {
        max-width: 720px;
        margin: 0 auto;
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 16px;
      }
      nav {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
      }
      nav a {
        color: #fff;
        text-decoration: none;
        padding: 8px 16px;
        border-radius: 8px;
        background: rgba(255,255,255,0.1);
        transition: background 0.2s;
      }
      nav a:hover {
        background: rgba(255,255,255,0.2);
      }
      nav a.active {
        background: #6366f1;
      }
      .user-area {
        display: flex;
        align-items: center;
        gap: 12px;
      }
      .user-name {
        color: #a5b4fc;
        font-size: 14px;
      }
      .btn-auth {
        color: #fff;
        text-decoration: none;
        padding: 8px 16px;
        border-radius: 8px;
        background: #6366f1;
        border: none;
        font: inherit;
        cursor: pointer;
        transition: background 0.2s;
      }
      .btn-auth:hover {
        background: #4f46e5;
      }
      .btn-logout {
        background: #ef4444;
      }
      .btn-logout:hover {
        background: #dc2626;
      }
      main {
        max-width: 720px;
        margin: 40px auto;
        padding: 0 16px;
      }
      form {
        display: grid;
        gap: 12px;
        border: 1px solid #ddd;
        padding: 16px;
        border-radius: 12px;
      }
      input, textarea, button {
        font: inherit;
        padding: 10px;
      }
      textarea { min-height: 120px; }
      .ok {
        padding: 12px;
        border-radius: 10px;
        background: #eefbf0;
        border: 1px solid #bde5c4;
        margin-bottom: 16px;
      }
      .err {
        padding: 12px;
        border-radius: 10px;
        background: #fff0f0;
        border: 1px solid #f0b6b6;
        margin-bottom: 16px;
      }
      code { background: #f6f6f6; padding: 2px 6px; border-radius: 6px; }
      .badge {
        display: inline-block;
        font-size: 12px;
        padding: 4px 8px;
        border-radius: 4px;
        background: #e0e7ff;
        color: #3730a3;
        margin-left: 8px;
      }
      .welcome-msg {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        padding: 16px;
        border-radius: 12px;
        margin-bottom: 20px;
      }
    </style>
  </head>

  <body>
    <header>
      <div class="header-content">
        <nav>
          <a href="/" class:list={{ active: currentPath === '/' }}>
            Form POST
          </a>
          <a href="/con-redirect" class:list={{ active: currentPath === '/con-redirect' }}>
            Con Redirect
          </a>
          <a href="/con-js" class:list={{ active: currentPath === '/con-js' }}>
            Con JavaScript
          </a>
        </nav>

        <div class="user-area">
          {user ? (
            <>
              <span class="user-name">Hola, <span id="userName">{user.nombre}</span></span>
              <form method="POST" action={actions.logout} style="display:inline; border:none; padding:0;">
                <button type="submit" class="btn-auth btn-logout">Cerrar sesión</button>
              </form>
            </>
          ) : (
            <a href="/login" class="btn-auth">Iniciar sesión</a>
          )}
        </div>
      </div>
    </header>

    <main>
      {user && (
        <div class="welcome-msg">
          Bienvenido, <strong>{user.nombre}</strong>
        </div>
      )}
      <slot />
    </main>

    <script>
      // Sincronizar datos de usuario con localStorage
      const userDataCookie = document.cookie
        .split('; ')
        .find(row => row.startsWith('user_data='));

      if (userDataCookie) {
        const userData = JSON.parse(decodeURIComponent(userDataCookie.split('=')[1]));
        localStorage.setItem('userData', JSON.stringify(userData));
      } else {
        localStorage.removeItem('userData');
      }
    </script>
  </body>
</html>
