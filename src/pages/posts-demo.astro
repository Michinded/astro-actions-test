---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Demo CRUD - Múltiples Actions con JS">
  <main>
    <h1>Demo: Múltiples Actions con JavaScript</h1>
    <p class="intro">
      CRUD completo sin recargar la página. Cada formulario llama a una action diferente vía JS.
    </p>

    <div class="grid">
      <!-- ============ FORMULARIO 1: CREAR POST ============ -->
      <section class="card">
        <h2>📝 Crear Nuevo Post</h2>
        <form id="createForm">
          <div class="field">
            <label for="create-titulo">Título:</label>
            <input
              type="text"
              id="create-titulo"
              name="titulo"
              required
              maxlength="100"
              placeholder="Escribe el título..."
            />
          </div>
          <div class="field">
            <label for="create-contenido">Contenido:</label>
            <textarea
              id="create-contenido"
              name="contenido"
              required
              rows="3"
              placeholder="Escribe el contenido..."
            ></textarea>
          </div>
          <button type="submit" class="btn-primary">Crear Post</button>
        </form>
        <div id="createResult"></div>
      </section>

      <!-- ============ FORMULARIO 2: EDITAR POST ============ -->
      <section class="card">
        <h2>✏️ Editar Post</h2>
        <form id="updateForm">
          <div class="field">
            <label for="edit-id">Selecciona post:</label>
            <select id="edit-id" name="id" required>
              <option value="">Cargando...</option>
            </select>
          </div>
          <div class="field">
            <label for="edit-titulo">Nuevo Título:</label>
            <input
              type="text"
              id="edit-titulo"
              name="titulo"
              required
              maxlength="100"
              placeholder="Nuevo título..."
            />
          </div>
          <div class="field">
            <label for="edit-contenido">Nuevo Contenido:</label>
            <textarea
              id="edit-contenido"
              name="contenido"
              required
              rows="3"
              placeholder="Nuevo contenido..."
            ></textarea>
          </div>
          <button type="submit" class="btn-warning">Actualizar Post</button>
        </form>
        <div id="updateResult"></div>
      </section>
    </div>

    <!-- ============ LISTA DE POSTS ============ -->
    <section class="posts-list">
      <h2>📋 Posts Existentes (<span id="postCount">0</span>)</h2>
      <div id="postsList">
        <p class="loading">Cargando posts...</p>
      </div>
    </section>

    <!-- ============ SECCIÓN EDUCATIVA ============ -->
    <section class="info">
      <h2>💡 ¿Cómo funciona?</h2>
      <ul>
        <li>Las actions se llaman con <code>actions.postsCreate(...)</code> desde JavaScript</li>
        <li>No hay recarga de página - todo es asíncrono</li>
        <li>Cada action devuelve <code>&#123; data, error &#125;</code></li>
        <li>La lista se actualiza automáticamente después de cada operación</li>
      </ul>

      <h3>Código clave:</h3>
      <pre><code>{`// En el <script>
import { actions } from 'astro:actions';

// Crear
const { data, error } = await actions.postsCreate({
  titulo: 'Mi post',
  contenido: 'Contenido...'
});

// Eliminar
await actions.postsDelete({ id: '123' });

// Listar
const { data } = await actions.postsList();`}</code></pre>
    </section>

    <a href="/" class="back-link">← Volver al inicio</a>
  </main>
</Layout>

<script>
  import { actions } from 'astro:actions';

  // Referencias DOM
  const createForm = document.getElementById('createForm') as HTMLFormElement;
  const createResult = document.getElementById('createResult') as HTMLDivElement;
  const updateForm = document.getElementById('updateForm') as HTMLFormElement;
  const updateResult = document.getElementById('updateResult') as HTMLDivElement;
  const editSelect = document.getElementById('edit-id') as HTMLSelectElement;
  const editTitulo = document.getElementById('edit-titulo') as HTMLInputElement;
  const editContenido = document.getElementById('edit-contenido') as HTMLTextAreaElement;
  const postsList = document.getElementById('postsList') as HTMLDivElement;
  const postCount = document.getElementById('postCount') as HTMLSpanElement;

  // ============ CARGAR Y RENDERIZAR POSTS ============
  async function loadPosts() {
    const { data, error } = await actions.postsList();

    if (error) {
      postsList.innerHTML = `<p class="error">Error: ${error.message}</p>`;
      return;
    }

    const posts = data.posts;
    postCount.textContent = String(posts.length);

    // Actualizar select de edición
    editSelect.innerHTML = posts.length === 0
      ? '<option value="">No hay posts</option>'
      : '<option value="">Selecciona un post...</option>' +
        posts.map(p => `<option value="${p.id}">${p.titulo}</option>`).join('');

    // Renderizar lista
    if (posts.length === 0) {
      postsList.innerHTML = '<p class="empty">No hay posts. ¡Crea uno arriba!</p>';
      return;
    }

    postsList.innerHTML = posts.map(post => `
      <article class="post-item" data-id="${post.id}">
        <div class="post-content">
          <h3>${post.titulo}</h3>
          <p>${post.contenido}</p>
          <small>ID: ${post.id}</small>
        </div>
        <button class="btn-danger delete-btn" data-id="${post.id}">
          🗑️ Eliminar
        </button>
      </article>
    `).join('');

    // Agregar listeners a botones de eliminar
    document.querySelectorAll('.delete-btn').forEach(btn => {
      btn.addEventListener('click', handleDelete);
    });
  }

  // ============ CREAR POST ============
  createForm.addEventListener('submit', async (e) => {
    e.preventDefault();

    const formData = new FormData(createForm);
    const titulo = formData.get('titulo') as string;
    const contenido = formData.get('contenido') as string;

    createResult.innerHTML = '<p class="loading">Creando...</p>';

    const { data, error } = await actions.postsCreate({ titulo, contenido });

    if (error) {
      createResult.innerHTML = `<div class="error">❌ ${error.message}</div>`;
      return;
    }

    createResult.innerHTML = `<div class="success">✅ Post creado: "${data.post.titulo}"</div>`;
    createForm.reset();

    // Recargar lista
    await loadPosts();

    // Limpiar mensaje después de 3s
    setTimeout(() => { createResult.innerHTML = ''; }, 3000);
  });

  // ============ CARGAR DATOS AL SELECCIONAR POST ============
  editSelect.addEventListener('change', async () => {
    const id = editSelect.value;
    if (!id) {
      editTitulo.value = '';
      editContenido.value = '';
      return;
    }

    const { data, error } = await actions.postsGet({ id });

    if (error) {
      updateResult.innerHTML = `<div class="error">❌ ${error.message}</div>`;
      return;
    }

    editTitulo.value = data.post.titulo;
    editContenido.value = data.post.contenido;
  });

  // ============ ACTUALIZAR POST ============
  updateForm.addEventListener('submit', async (e) => {
    e.preventDefault();

    const formData = new FormData(updateForm);
    const id = formData.get('id') as string;
    const titulo = formData.get('titulo') as string;
    const contenido = formData.get('contenido') as string;

    if (!id) {
      updateResult.innerHTML = '<div class="error">❌ Selecciona un post primero</div>';
      return;
    }

    updateResult.innerHTML = '<p class="loading">Actualizando...</p>';

    const { data, error } = await actions.postsUpdate({ id, titulo, contenido });

    if (error) {
      updateResult.innerHTML = `<div class="error">❌ ${error.message}</div>`;
      return;
    }

    updateResult.innerHTML = `<div class="success">✅ Post actualizado: "${data.post.titulo}"</div>`;
    updateForm.reset();

    // Recargar lista
    await loadPosts();

    setTimeout(() => { updateResult.innerHTML = ''; }, 3000);
  });

  // ============ ELIMINAR POST ============
  async function handleDelete(e: Event) {
    const btn = e.target as HTMLButtonElement;
    const id = btn.dataset.id!;

    if (!confirm('¿Eliminar este post?')) return;

    btn.disabled = true;
    btn.textContent = '⏳';

    const { error } = await actions.postsDelete({ id });

    if (error) {
      alert(`Error: ${error.message}`);
      btn.disabled = false;
      btn.textContent = '🗑️ Eliminar';
      return;
    }

    // Recargar lista
    await loadPosts();
  }

  // ============ CARGAR AL INICIO ============
  loadPosts();
</script>

<style>
  main {
    max-width: 900px;
    margin: 0 auto;
    padding: 2rem;
  }

  h1 {
    color: #333;
    margin-bottom: 0.5rem;
  }

  .intro {
    color: #666;
    margin-bottom: 2rem;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1.5rem;
    margin-bottom: 2rem;
  }

  .card {
    background: #fff;
    border: 1px solid #ddd;
    border-radius: 8px;
    padding: 1.5rem;
  }

  .card h2 {
    margin-top: 0;
    font-size: 1.2rem;
    color: #333;
  }

  .field {
    margin-bottom: 1rem;
  }

  .field label {
    display: block;
    margin-bottom: 0.3rem;
    font-weight: 500;
    color: #555;
  }

  .field input,
  .field textarea,
  .field select {
    width: 100%;
    padding: 0.5rem;
    border: 1px solid #ccc;
    border-radius: 4px;
    font-size: 1rem;
    box-sizing: border-box;
  }

  button {
    padding: 0.6rem 1.2rem;
    border: none;
    border-radius: 4px;
    cursor: pointer;
    font-size: 0.9rem;
    font-weight: 500;
  }

  button:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  .btn-primary {
    background: #0066cc;
    color: white;
  }

  .btn-primary:hover:not(:disabled) {
    background: #0055aa;
  }

  .btn-warning {
    background: #ff9900;
    color: white;
  }

  .btn-warning:hover:not(:disabled) {
    background: #dd8800;
  }

  .btn-danger {
    background: #dc3545;
    color: white;
  }

  .btn-danger:hover:not(:disabled) {
    background: #bb2d3b;
  }

  .error {
    margin-top: 1rem;
    padding: 0.75rem;
    background: #ffebee;
    color: #c62828;
    border-radius: 4px;
  }

  .success {
    margin-top: 1rem;
    padding: 0.75rem;
    background: #e8f5e9;
    color: #2e7d32;
    border-radius: 4px;
  }

  .loading {
    color: #666;
    font-style: italic;
  }

  .posts-list {
    background: #f9f9f9;
    border-radius: 8px;
    padding: 1.5rem;
    margin-bottom: 2rem;
  }

  .posts-list h2 {
    margin-top: 0;
  }

  .empty {
    color: #888;
    font-style: italic;
  }

  .post-item {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    background: white;
    padding: 1rem;
    border-radius: 6px;
    border: 1px solid #eee;
    margin-bottom: 1rem;
  }

  .post-item:last-child {
    margin-bottom: 0;
  }

  .post-content {
    flex: 1;
  }

  .post-content h3 {
    margin: 0 0 0.5rem 0;
    font-size: 1rem;
  }

  .post-content p {
    margin: 0 0 0.5rem 0;
    color: #666;
  }

  .post-content small {
    color: #999;
    font-family: monospace;
  }

  .info {
    background: #e3f2fd;
    border-radius: 8px;
    padding: 1.5rem;
    margin-bottom: 2rem;
  }

  .info h2 {
    margin-top: 0;
    color: #1565c0;
  }

  .info h3 {
    margin-bottom: 0.5rem;
  }

  .info ul {
    margin: 0 0 1rem 0;
    padding-left: 1.5rem;
  }

  .info li {
    margin-bottom: 0.5rem;
  }

  .info code {
    background: #bbdefb;
    padding: 0.1rem 0.3rem;
    border-radius: 3px;
  }

  .info pre {
    background: #1e1e1e;
    color: #d4d4d4;
    padding: 1rem;
    border-radius: 4px;
    overflow-x: auto;
    font-size: 0.85rem;
  }

  .back-link {
    display: inline-block;
    color: #0066cc;
    text-decoration: none;
  }

  .back-link:hover {
    text-decoration: underline;
  }
</style>
