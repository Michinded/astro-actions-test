---
export const prerender = false;

import MainLayout from '../layouts/MainLayout.astro';
import { actions } from 'astro:actions';

const result = Astro.getActionResult(actions.enviarAApi);

// Si hay resultado exitoso, redirigir para limpiar la URL
if (result && !result.error) {
  // Guardamos el resultado en una cookie para mostrarlo después del redirect
  const resultData = JSON.stringify(result.data);
  Astro.cookies.set('actionResult', resultData, {
    path: '/',
    maxAge: 60,
    httpOnly: true,  // No accesible desde JavaScript
    sameSite: 'strict',  // Solo se envía en requests del mismo sitio
    secure: import.meta.env.PROD,  // HTTPS en producción
  });
  return Astro.redirect('/con-redirect');
}

// Leemos el resultado de la cookie (si existe)
const cookieResult = Astro.cookies.get('actionResult');
let savedResult = null;
if (cookieResult) {
  savedResult = JSON.parse(cookieResult.value);
  // Eliminamos la cookie después de leerla
  Astro.cookies.delete('actionResult', { path: '/' });
}
---

<MainLayout title="Con Redirect - Astro Actions">
  <h1>Con Redirect <span class="badge">URL Limpia</span></h1>
  <p>Después de enviar, el servidor hace redirect para limpiar el parámetro <code>?_action</code> de la URL. Usamos una cookie temporal para preservar el resultado.</p>

  {savedResult && (
    <div class="ok">
      <p><strong>✅ Enviado!</strong> La API respondió con <code>id={savedResult.apiId}</code></p>
      <p><strong>Echo:</strong></p>
      <pre>{JSON.stringify(savedResult.echo, null, 2)}</pre>
    </div>
  )}

  {result?.error && (
    <div class="err">
      <p><strong>❌ Error:</strong> No se pudo enviar.</p>
      <p>Intenta de nuevo.</p>
    </div>
  )}

  <form method="POST" action={actions.enviarAApi}>
    <label>
      Nombre
      <input name="nombre" required />
    </label>

    <label>
      Mensaje
      <textarea name="mensaje" required></textarea>
    </label>

    <button type="submit">Enviar</button>
  </form>
</MainLayout>
